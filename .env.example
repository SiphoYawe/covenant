# .env.example — All required environment variables for Covenant
# Copy to .env.local and fill in real values

# Claude AI
ANTHROPIC_API_KEY=

# Agent wallet private keys (Base Sepolia testnet)
AGENT_A_PRIVATE_KEY=
AGENT_B_PRIVATE_KEY=
AGENT_C_PRIVATE_KEY=
AGENT_D_PRIVATE_KEY=
SYSTEM_PRIVATE_KEY=

# Base Sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Pinata IPFS
PINATA_JWT=

# Upstash Redis (replaces Vercel KV)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Civic MCP
CIVIC_MCP_ENDPOINT=

# Civic Auth (optional, enables human deploy mode)
CIVIC_CLIENT_ID=
CIVIC_CLIENT_SECRET=

# x402 Payment Facilitator
X402_FACILITATOR_URL=

# Sentry
SENTRY_DSN=

# Public (available in client bundle)
NEXT_PUBLIC_BASE_SEPOLIA_CHAIN_ID=84532
